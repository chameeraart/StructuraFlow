@model ValidationRule
@{
    ViewData["Title"] = "Validation Rules Editor";
}

<div class="container mt-4">
    <h2 class="mb-4">Validation Rules Editor</h2>

    <form method="post" asp-action="Update">
        <div class="row g-3">

            <!-- Boolean Rules -->
            <div class="col-md-6">
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-primary text-white">Boolean Validation Rules</div>
                    <div class="card-body">
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckDuplicateColumns" />
                            <label class="form-check-label" asp-for="CheckDuplicateColumns"></label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckDuplicateBeams" />
                            <label class="form-check-label" asp-for="CheckDuplicateBeams"></label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckDuplicateSlabs" />
                            <label class="form-check-label" asp-for="CheckDuplicateSlabs"></label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckNegativeValues" />
                            <label class="form-check-label" asp-for="CheckNegativeValues"></label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckMissingFields" />
                            <label class="form-check-label" asp-for="CheckMissingFields"></label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckBeamReferences" />
                            <label class="form-check-label" asp-for="CheckBeamReferences"></label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" asp-for="CheckBeamStartEndSame" />
                            <label class="form-check-label" asp-for="CheckBeamStartEndSame"></label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Numeric Rules -->
            <div class="col-md-6">
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-success text-white">Numeric Validation Rules</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label asp-for="MinColumnHeight" class="form-label"></label>
                            <input class="form-control" type="number" step="0.01" asp-for="MinColumnHeight" />
                            <span class="text-danger" asp-validation-for="MinColumnHeight"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MinColumnWidth" class="form-label"></label>
                            <input class="form-control" type="number" step="0.01" asp-for="MinColumnWidth" />
                            <span class="text-danger" asp-validation-for="MinColumnWidth"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MinBeamLength" class="form-label"></label>
                            <input class="form-control" type="number" step="0.01" asp-for="MinBeamLength" />
                            <span class="text-danger" asp-validation-for="MinBeamLength"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="MinSlabThickness" class="form-label"></label>
                            <input class="form-control" type="number" step="0.01" asp-for="MinSlabThickness" />
                            <span class="text-danger" asp-validation-for="MinSlabThickness"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary btn-lg">Save Rules</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}